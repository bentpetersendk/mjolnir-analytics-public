# SQLite and database files
*.sqlite
*.sqlite3
*.db
*.db-*
*.sqlite-wal
*.sqlite-shm
*.sqlite-journal

# Logs
*.log
logs/

# Backups
backups/
backup/
*.bak
*.backup

# Temporary files
tmp/
temp/
*.tmp

# Generated JSON exports
data/exports/
exports/
*.generated.json
*-export.json
*_export.json

# Python cache files
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Local environment files
.env
.env.*
!.env.example

# Public-safe deployment guardrails
#
# data/node_insights.sqlite (matched by the *.sqlite rule above) is the
# Node Insights raw database and must never be pushed to GitHub Pages.
# site/data/*.json (scripts/export_node_insights.py output) is the only
# Node Insights data this repo publishes - it is intentionally NOT
# ignored here so scripts/publish_dashboard.sh can commit it.
